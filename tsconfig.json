{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@lib/*": ["./lib/*"],
      "@api/*": ["./lib/api/*"],
      "@pages/*": ["./lib/pages/*"],
      "@fixtures/*": ["./lib/fixtures/*"],
      "@datafactory/*": ["./lib/datafactory/*"],
      "@helpers/*": ["./lib/helpers/*"]
    }
  },
  "include": [
    "**/*.ts",
    "playwright.config.ts",
    "global.setup.ts"
  ],
  "exclude": ["node_modules"]
}
